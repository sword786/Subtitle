{
  "appId": "com.captifyai.app",
  "productName": "Captify AI",
  "copyright": "Copyright © 2026 Captify AI",
  "directories": {
    "output": "dist_desktop",
    "buildResources": "assets/desktop"
  },
  "files": [
    "dist/**/*",
    "electron-main.cjs",
    "electron-preload.js",
    "package.json",
    "public/**/*"
  ],
  "asar": true,
  "win": {
    "target": ["nsis", "portable"]
  },
  "mac": {
    "target": ["dmg", "zip"],
    "category": "public.app-category.video",
    "identity": null
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Video"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Captify AI"
  },
  "dmg": {
    "background": null,
    "backgroundColor": "#09090B",
    "window": {
      "width": 540,
      "height": 380
    },
    "contents": [
      {
        "x": 130,
        "y": 150,
        "type": "file"
      },
      {
        "x": 410,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      }
    ]
  }
}
